---

# Generic
generic:
  role: ansible-role-sudo
  role_short: sudo
  role_description: |
    Installs/configures sudo with optional hardening
  collections: []

# Supported platforms
platforms:
  ubuntu2004:
    supported: true
    ci: true

molecule:
  requirements:
    roles_extra: []
  converge:
    vars:
      sudo_hardening: true
